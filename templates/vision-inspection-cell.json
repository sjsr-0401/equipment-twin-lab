{
  "name": "vision-inspection-cell",
  "description": "Minimal configurable cell with X/Z motion axes and dataset-camera product recipes.",
  "motionAxes": [
    {
      "name": "X",
      "initialPosition": 0,
      "requiresHome": true
    },
    {
      "name": "Z",
      "initialPosition": 0,
      "requiresHome": true
    }
  ],
  "productRecipes": [
    {
      "name": "default-panel",
      "productCode": "PANEL-A",
      "inspectionMode": "DatasetCamera",
      "inspectionResult": {
        "outcome": "Pass",
        "message": "Panel vision inspection passed.",
        "measurements": {
          "edgeOffsetMm": 0.12,
          "surfaceScore": 98.5
        }
      },
      "axisTargets": {
        "X": 25,
        "Z": 5
      }
    },
    {
      "name": "tall-part",
      "productCode": "PART-TALL",
      "inspectionMode": "DatasetCamera",
      "inspectionResult": {
        "outcome": "Fail",
        "defectCode": "HEIGHT_OVER_LIMIT",
        "message": "Tall part height exceeded inspection limit.",
        "measurements": {
          "heightMm": 12.8,
          "heightLimitMm": 12
        }
      },
      "axisTargets": {
        "X": 40,
        "Z": 12
      }
    }
  ],
  "faultScenarios": [
    {
      "name": "x-axis-move-timeout",
      "kind": "MotionTimeout",
      "axis": "X",
      "timeoutMilliseconds": 500,
      "elapsedMilliseconds": 1000
    },
    {
      "name": "z-axis-servo-alarm",
      "kind": "ServoAlarm",
      "axis": "Z",
      "message": "Z axis servo amplifier alarm."
    }
  ]
}
