{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "CLI - normal cycle": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "scenarios\\normal-cycle.json"
    },
    "CLI - loading timeout": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "scenarios\\loading-timeout.json --default-timeouts"
    },
    "CLI - batch report": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "batch scenarios --default-timeouts --report artifacts\\scenario-report.md"
    },
    "CLI - template default panel": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "template run templates\\vision-inspection-cell.json default-panel --report artifacts\\template-run-report.md"
    },
    "CLI - template tall part": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "template run templates\\vision-inspection-cell.json tall-part"
    },
    "CLI - template fault": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "template run templates\\vision-inspection-cell.json default-panel --fault x-axis-move-timeout"
    }
  }
}
