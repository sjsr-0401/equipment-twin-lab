{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "CLI - normal cycle": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "scenarios\\normal-cycle.json"
    },
    "CLI - loading timeout": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "scenarios\\loading-timeout.json --default-timeouts"
    },
    "CLI - batch report": {
      "commandName": "Project",
      "workingDirectory": "..\\..",
      "commandLineArgs": "batch scenarios --default-timeouts --report artifacts\\scenario-report.md"
    }
  }
}
