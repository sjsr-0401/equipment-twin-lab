{
  "name": "clear-alarm-recovery",
  "description": "Creates a door-open alarm, restores the door input, and verifies ClearAlarm returns the equipment to Idle.",
  "steps": [
    {
      "name": "Start cycle",
      "action": "StartCycle",
      "expectState": "Loading"
    },
    {
      "name": "Door opens",
      "action": "SetInput",
      "signal": "DI_DOOR_CLOSED",
      "value": false
    },
    {
      "name": "Poll door alarm",
      "action": "PollInputs",
      "expectState": "Alarmed",
      "expectSignals": {
        "DO_TOWER_LAMP_RED": true,
        "DO_BUZZER_ON": true
      }
    },
    {
      "name": "Door closes again",
      "action": "SetInput",
      "signal": "DI_DOOR_CLOSED",
      "value": true
    },
    {
      "name": "Clear alarm",
      "action": "ClearAlarm",
      "expectState": "Idle",
      "expectSignals": {
        "DO_VACUUM_ON": false,
        "DO_STAGE_MOVE_REQUESTED": false,
        "DO_TOWER_LAMP_RED": false,
        "DO_BUZZER_ON": false
      }
    }
  ]
}
